---
import fs from "node:fs";

// The version has one home: laydown/__init__.py. Read it at build time rather
// than restate it here, or the site will eventually advertise a version that isn't
// the one on the releases page.
const initPy = fs.readFileSync(
  new URL("../../../laydown/__init__.py", import.meta.url),
  "utf8",
);
const match = initPy.match(/__version__\s*=\s*"([^"]+)"/);
if (!match) throw new Error("Could not read __version__ from laydown/__init__.py");
const version = match[1];

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const title = "Laydown — free PDF imposition for print";
const description =
  "Free, open-source PDF imposition. Lay your pages out on the press sheet — n-up, booklets, marks and bleed — on Windows, macOS and Linux. Runs on your machine, nothing uploaded.";
const author = "Daniel Mevit";
const repo = "https://github.com/danielmevit/laydown";
const releases = `${repo}/releases`;
const latest = `${repo}/releases/latest`;
const year = 2026;

const features = [
  {
    title: "Pages stay sharp",
    body: "Your pages are embedded as vectors, never re-rendered into pictures. What comes off the press is exactly as crisp as what you put in — text is still text.",
  },
  {
    title: "It reads print files properly",
    body: "If your PDF has a trim box and bleed, Laydown uses them: it places the finished page and carries your bleed past the cut line. Ordinary PDFs with no boxes work fine too.",
  },
  {
    title: "The preview is the sheet",
    body: "What you see is rendered from a real imposition, and the pink outlines are the cut lines that run actually used. It can't show you one thing and print another.",
  },
  {
    title: "It speaks up early",
    body: "Margins that don't fit, a missing trim box, pages quietly being shrunk — Laydown says so while you can still fix it, instead of letting you find out at the guillotine.",
  },
  {
    title: "Booklets that fold right",
    body: "Saddle stitch or perfect binding with signatures. Page order is worked out for you, and creep compensation evens up the margins on thicker booklets.",
  },
  {
    title: "Your marks, your way",
    body: "Crop, gap crop, registration, fold, perforation, collating marks and a colour bar. Need your own bull's-eye or house colour bar? Point it at a PDF and it gets stamped on.",
  },
];

const faqs = [
  {
    q: "Does it upload my documents?",
    a: "No. There's no network code in it at all. It opens your file, writes a new one, and that's the whole story.",
  },
  {
    q: "Does it cost anything?",
    a: "No, and there's no paid tier. It's AGPL-3.0 — free to use, study and modify.",
  },
  {
    q: "Will my pages lose quality?",
    a: "No. Pages are placed as vectors rather than rasterised, so the output matches the source exactly.",
  },
  {
    q: "What's creep?",
    a: "Nest folded sheets inside each other and the inner pages stick out further at the open edge. Trimming the stack flush takes more off them, so their margins end up narrower. Creep compensation nudges the pages to even that out. On a thin booklet you can ignore it.",
  },
  {
    q: "Can it do work-and-turn?",
    a: "Not yet. That's a press technique where both forms go on one plate, and getting it subtly wrong wastes plates and paper — so it stays out until someone who runs a press has checked it.",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/assets/icon_32.png`} />
    <link rel="icon" type="image/png" sizes="256x256" href={`${base}/assets/icon_256.png`} />

    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="pdf imposition, imposition software, n-up pdf, booklet printing, saddle stitch imposition, perfect binding, impose pdf pages, crop marks, bleed and trim, prepress software, free imposition software, open source imposition, Imposition Wizard alternative, Quite Imposing alternative, signature imposition, page creep, gang up printing, print shop software"
    />
    <meta name="author" content={author} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://danielmevit.github.io/laydown/" />
    <meta
      property="og:image"
      content="https://raw.githubusercontent.com/DanielMevit/Laydown/main/assets/screenshot.png"
    />
    <meta property="og:site_name" content="Laydown" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Laydown",
      applicationCategory: "DesignApplication",
      operatingSystem: "Windows 10, Windows 11, macOS 11+, Linux",
      description:
        "Free, open-source PDF imposition for commercial printing. N-up, booklets, signatures, creep, printer marks, bleed and trim-box aware. Runs locally.",
      url: "https://danielmevit.github.io/laydown/",
      downloadUrl: "https://github.com/danielmevit/laydown/releases",
      softwareVersion: version,
      author: { "@type": "Person", name: author, url: "https://github.com/danielmevit" },
      license: "https://www.gnu.org/licenses/agpl-3.0.html",
      isAccessibleForFree: true,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    })} />

    <style is:global>
      :root {
        /* Laydown's own palette: warm ink on press-black, not a tech blue. */
        --bg: #0a0a0a;
        --bg-soft: #101010;
        --card: #151515;
        --card-hover: #1c1a18;
        --text: #c8c6c3;
        --heading: #ffffff;
        --muted: #8a8784;
        --border: #2a2724;
        --accent: #d07b24;
        --accent-hi: #e8912f;
        --accent-deep: #a8631c;
        --ink: #ff0090; /* the preview overlay colour — used sparingly, as in the app */
        --radius: 14px;
        --wrap: 1080px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.65;
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }

      img { max-width: 100%; height: auto; display: block; }
      a { color: var(--accent-hi); }

      .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 1.5rem; }

      h1, h2, h3 { color: var(--heading); line-height: 1.2; }

      /* ---------- nav ---------- */
      nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.1rem 0; gap: 1rem;
      }
      .brand {
        display: flex; align-items: center; gap: 0.6rem;
        font-weight: 700; color: var(--heading); text-decoration: none; font-size: 1.15rem;
      }
      .brand .glyph {
        width: 26px; height: 26px; border-radius: 5px;
        background: linear-gradient(150deg, var(--accent-hi), var(--accent-deep));
        position: relative; flex: none;
      }
      .brand .glyph::after {
        content: ""; position: absolute; inset: 6px 6px auto 6px; height: 2px;
        background: rgba(255, 255, 255, 0.85); box-shadow: 0 5px 0 rgba(255,255,255,.55);
      }
      nav .links { display: flex; align-items: center; gap: 1.3rem; }
      nav .links a {
        color: var(--muted); text-decoration: none; font-weight: 500; font-size: 0.95rem;
      }
      nav .links a:hover { color: var(--heading); }

      .btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--accent); color: #fff !important;
        padding: 0.7rem 1.25rem; border-radius: 999px;
        font-weight: 600; text-decoration: none; border: 1px solid transparent;
        transition: background .12s ease, transform .12s ease;
      }
      .btn:hover { background: var(--accent-hi); transform: translateY(-1px); }
      .btn.ghost { background: transparent; color: var(--text) !important; border-color: var(--border); }
      .btn.ghost:hover { border-color: var(--muted); background: transparent; }
      .btn.big { padding: 0.9rem 1.6rem; font-size: 1.02rem; }

      /* ---------- hero ---------- */
      .hero { padding: 3.5rem 0 1rem; text-align: center; }
      .hero h1 { font-size: clamp(2.1rem, 5vw, 3.3rem); margin: 0 0 1rem; letter-spacing: -0.02em; }
      .hero h1 .hl { color: var(--accent-hi); }
      .hero p.lead {
        font-size: clamp(1.05rem, 2vw, 1.2rem); max-width: 640px; margin: 0 auto 1.6rem;
        color: var(--text);
      }
      .cta { display: flex; gap: 0.7rem; justify-content: center; flex-wrap: wrap; }
      .under-cta { color: var(--muted); font-size: 0.85rem; margin-top: 0.9rem; }

      .shot {
        margin: 2.5rem auto 0; border: 1px solid var(--border); border-radius: var(--radius);
        overflow: hidden; box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
      }

      /* ---------- sections ---------- */
      section { padding: 3.5rem 0; }
      .section-head { text-align: center; margin-bottom: 2.2rem; }
      .section-head h2 { font-size: clamp(1.5rem, 3vw, 2rem); margin: 0 0 0.5rem; }
      .section-head p { color: var(--muted); margin: 0; }

      .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); }
      .card {
        background: var(--card); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 1.4rem;
        transition: background .15s ease, border-color .15s ease;
      }
      .card:hover { background: var(--card-hover); border-color: #3a352f; }
      .card h3 { margin: 0 0 0.5rem; font-size: 1.05rem; }
      .card p { margin: 0; font-size: 0.95rem; color: var(--text); }

      /* ---------- steps ---------- */
      .steps { counter-reset: step; display: grid; gap: 0.9rem; max-width: 720px; margin: 0 auto; }
      .step {
        display: flex; gap: 1rem; align-items: flex-start;
        background: var(--card); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 1.1rem 1.3rem;
      }
      .step .n {
        counter-increment: step; flex: none;
        width: 28px; height: 28px; border-radius: 50%;
        background: var(--accent); color: #fff; font-weight: 700; font-size: 0.9rem;
        display: grid; place-items: center;
      }
      .step .n::before { content: counter(step); }
      .step p { margin: 0.15rem 0 0; }
      .step b { color: var(--heading); }

      /* ---------- downloads ---------- */
      .dl-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
      .dl {
        background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.3rem; text-align: center;
      }
      .dl h3 { margin: 0 0 0.2rem; font-size: 1rem; }
      .dl .os { color: var(--muted); font-size: 0.85rem; margin: 0 0 0.9rem; }
      .dl a { font-size: 0.92rem; }
      .note {
        margin-top: 1.4rem; padding: 0.9rem 1.1rem; border-radius: 10px;
        background: var(--bg-soft); border: 1px solid var(--border);
        color: var(--muted); font-size: 0.88rem;
      }

      /* ---------- faq ---------- */
      .faq { max-width: 760px; margin: 0 auto; }
      details {
        border-bottom: 1px solid var(--border); padding: 1rem 0;
      }
      details summary {
        cursor: pointer; font-weight: 600; color: var(--heading); list-style: none;
        display: flex; justify-content: space-between; gap: 1rem; align-items: center;
      }
      details summary::-webkit-details-marker { display: none; }
      details summary::after { content: "+"; color: var(--accent-hi); font-weight: 700; }
      details[open] summary::after { content: "–"; }
      details p { margin: 0.7rem 0 0; color: var(--text); }

      /* ---------- footer ---------- */
      footer {
        border-top: 1px solid var(--border); padding: 2.2rem 0 3rem;
        color: var(--muted); font-size: 0.88rem;
      }
      footer .row { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
      footer a { color: var(--muted); }
      footer a:hover { color: var(--heading); }
      .warn { margin-top: 1rem; color: var(--muted); }

      @media (max-width: 640px) {
        nav .links a:not(.btn) { display: none; }
        .hero { padding-top: 2rem; }
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <nav>
        <a class="brand" href={`${base}/`}>
          <span class="glyph"></span> Laydown
        </a>
        <div class="links">
          <a href="#features">Features</a>
          <a href="#how">How it works</a>
          <a href="#faq">FAQ</a>
          <a href={repo}>GitHub</a>
          <a class="btn" href="#download">Download</a>
        </div>
      </nav>
    </div>

    <header class="wrap hero">
      <h1>Put your pages on the <span class="hl">press sheet</span></h1>
      <p class="lead">
        Laydown lays PDF pages out for printing — two-up on A3, a saddle-stitched
        booklet, a sheet of labels — so they come out right after they're printed,
        folded and cut. Free, open source, and it runs on your machine.
      </p>
      <div class="cta">
        <a class="btn big" href="#download">Download for free</a>
        <a class="btn big ghost" href={repo}>View source</a>
      </div>
      <p class="under-cta">
        Windows · macOS · Linux — v{version} · AGPL-3.0 · nothing uploaded, no account
      </p>

      <div class="shot">
        <img
          src={`${base}/assets/screenshot.png`}
          width="1600" height="980"
          alt="Laydown laying a 16-page booklet out on A3 sheets, with the settings panel showing booklet binding, creep and gutter controls"
        />
      </div>
    </header>

    <section id="features" class="wrap">
      <div class="section-head">
        <h2>Built for work that goes to press</h2>
        <p>The details that decide whether a job comes back right.</p>
      </div>
      <div class="grid">
        {features.map((f) => (
          <div class="card">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="how" style="background: var(--bg-soft); border-block: 1px solid var(--border);">
      <div class="wrap">
        <div class="section-head">
          <h2>Four steps</h2>
          <p>Open, choose, check, generate.</p>
        </div>
        <div class="steps">
          <div class="step"><span class="n"></span><p><b>Open your PDF.</b> Drag it onto the window, or Ctrl+O.</p></div>
          <div class="step"><span class="n"></span><p><b>Pick your sheet.</b> Size, how many pages go on it, marks and bleed.</p></div>
          <div class="step"><span class="n"></span><p><b>Check the preview.</b> That's your printed sheet — the pink outlines are where it gets cut.</p></div>
          <div class="step"><span class="n"></span><p><b>Generate PDF.</b> Send it to the printer.</p></div>
        </div>
      </div>
    </section>

    <section id="download" class="wrap">
      <div class="section-head">
        <h2>Download Laydown {version}</h2>
        <p>Free, no account, no strings. Everything's included — no Python needed.</p>
      </div>
      <div class="dl-grid">
        <div class="dl">
          <h3>Windows</h3>
          <p class="os">10 / 11 · 64-bit · installer or portable</p>
          <a class="btn" href={latest}>Get the installer</a>
          <p class="os" style="margin-top:.8rem">Portable ZIP also on the releases page</p>
        </div>
        <div class="dl">
          <h3>macOS</h3>
          <p class="os">11+ · Apple silicon &amp; Intel</p>
          <a class="btn" href={latest}>Get the .dmg</a>
          <p class="os" style="margin-top:.8rem">First launch: right-click → Open</p>
        </div>
        <div class="dl">
          <h3>Linux</h3>
          <p class="os">x86_64 · portable tar.gz</p>
          <a class="btn" href={latest}>Get the tarball</a>
          <p class="os" style="margin-top:.8rem">Extract and run — no install</p>
        </div>
      </div>
      <p class="note">
        The Windows and macOS builds aren't code-signed yet, so the first launch shows a
        "publisher unknown" warning — on Windows that's <b>More info → Run anyway</b>.
        Signing costs money and isn't there yet. You can always
        <a href={repo}>read the source</a> or build it yourself.
      </p>
    </section>

    <section id="faq" style="background: var(--bg-soft); border-block: 1px solid var(--border);">
      <div class="wrap">
        <div class="section-head"><h2>Questions</h2></div>
        <div class="faq">
          {faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <footer>
      <div class="wrap">
        <div class="row">
          <div>
            © {year} <a href="https://github.com/danielmevit">Daniel Mevit</a> · Made by
            <a href="https://damt.xyz">damt.xyz</a>
          </div>
          <div>
            <a href={repo}>GitHub</a> ·
            <a href={releases}>Releases</a> ·
            <a href={`${repo}/blob/main/CHANGELOG.md`}>Changelog</a> ·
            <a href="https://www.gnu.org/licenses/agpl-3.0.html">AGPL-3.0</a>
          </div>
        </div>
        <p class="warn">
          Provided "as is", without warranty. Always check your output before committing
          a job to press.
        </p>
      </div>
    </footer>
  </body>
</html>
